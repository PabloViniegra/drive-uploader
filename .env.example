# drive-uploader configuration
# Copy to .env in your config directory and fill in the values.
# Config directory:
#   Windows: %APPDATA%\DriveUploader\
#   Linux:   $XDG_CONFIG_HOME/drive-uploader/  (or ~/.config/drive-uploader/)

# --- Required ---

# Absolute path to the folder to watch for new files.
WATCH_FOLDER=

# ID of the target Google Drive folder.
DRIVE_FOLDER_ID=

# Absolute path to the Google Cloud credentials JSON file.
GOOGLE_CREDENTIALS=

# --- Optional (defaults shown) ---

# Number of concurrent upload workers.
# WORKERS=4

# Path to the SQLite queue file. Defaults to <config-dir>/drive_uploader.db.
# DATABASE=/var/lib/drive-uploader/drive_uploader.db

# Path to the OAuth token file. Defaults to <config-dir>/token.json.
# GOOGLE_TOKEN_PATH=/var/lib/drive-uploader/token.json

# Maximum retry attempts per job before marking it FAILED.
# RETRY_ATTEMPTS=3

# Seconds the dispatcher waits for in-flight jobs on shutdown.
# SHUTDOWN_GRACE_PERIOD=5.0

# Delete the local file after a successful upload (true/false).
# DELETE_AFTER_UPLOAD=false